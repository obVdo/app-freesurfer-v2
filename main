#!/bin/bash
#PBS -l nodes=1:ppn=8,vmem=40gb,walltime=20:00:00
#PBS -N bl.freesurfer
#SBATCH --job-name=test-hello
#SBATCH --ntasks-per-node=8
#SBATCH --mem=40G
#SBATCH --time=20:00:00
set -e
set -x

# Load proxy module (if your cluster provides one)
module load proxy
export HTTP_PROXY=$http_proxy
export HTTPS_PROXY=$https_proxy

# ── DIAGNOSTICS ───────────────────────────────────────────────
echo "=== PROXY ENV ==="
env | grep -i proxy || echo "NO PROXY VARS FOUND"

echo "=== SINGULARITY VARS ==="
env | grep -i singularity || echo "NO SINGULARITY VARS FOUND"

echo "=== TMPDIR INFO ==="
echo "TMPDIR=$TMPDIR"
df -h "$TMPDIR"
ls -la "$TMPDIR"

echo "=== SINGULARITY BINARY ==="
which singularity
ls -la "$(which singularity)"

echo "=== NETWORK TEST: proxy reachable? ==="
curl -s -o /dev/null -w "%{http_code}" --proxy "$http_proxy" https://registry-1.docker.io/v2/
echo " <- registry-1.docker.io (expect 401)"

echo "=== NETWORK TEST: direct (no proxy)? ==="
curl -s -o /dev/null -w "%{http_code}" --max-time 5 https://registry-1.docker.io/v2/ || true
echo " <- direct (expect 000 or timeout if firewall blocks)"

echo "=== SINGULARITY DEBUG PULL ==="
singularity --debug exec docker://hello-world /hello 2>&1 | head -80
# ── END DIAGNOSTICS ───────────────────────────────────────────

singularity --version
curl -sv --proxy "$http_proxy" https://auth.docker.io/token?service=registry.docker.io 2>&1 | tail -5
singularity exec docker://hello-world /hello
