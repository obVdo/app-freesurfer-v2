#!/bin/bash
#PBS -l nodes=1:ppn=8,vmem=40gb,walltime=20:00:00
#PBS -N bl.freesurfer

#SBATCH --ntasks-per-node=8
#SBATCH --mem=40G
#SBATCH --time=20:00:00

set -e
set -x

# Support both FREESURFER_LICENSE (content string) and FS_LICENSE (path to file)
if [ -n "$FREESURFER_LICENSE" ]; then
    echo $FREESURFER_LICENSE > license.txt
elif [ -n "$FS_LICENSE" ] && [ -f "$FS_LICENSE" ]; then
    cp "$FS_LICENSE" license.txt
else
    echo "Please set FREESURFER_LICENSE (content) or FS_LICENSE (path) in resource environment"
    exit 1
fi

singularity --version
which singularity

# FreeSurfer 7.4.1 needs MINC mritotal for Talairach - shim it with talairach_avi (built-in)
time singularity exec \
  -B `pwd`/license.txt:/opt/freesurfer/license.txt \
  docker://aunnikri642/app-freesurfer-mne-source-recon \
  bash -c "mkdir -p /usr/local/mni/bin && printf '#!/bin/bash\ntalairach_avi \"\$@\"\n' > /usr/local/mni/bin/mritotal && chmod +x /usr/local/mni/bin/mritotal && export MINC_BIN_DIR=/usr/local/mni/bin && bash ./freesurfer.sh"
