#!/bin/bash
#PBS -l nodes=1:ppn=8,vmem=25gb,walltime=18:00:00
#PBS -N bl.freesurfer

#SBATCH --ntasks-per-node=8
#SBATCH --mem=25G
#SBATCH --time=18:00:00

set -e
set -x

# Support both FREESURFER_LICENSE (content string) and FS_LICENSE (path to file)
if [ -n "$FREESURFER_LICENSE" ]; then
    echo $FREESURFER_LICENSE > license.txt
elif [ -n "$FS_LICENSE" ] && [ -f "$FS_LICENSE" ]; then
    cp "$FS_LICENSE" license.txt
else
    echo "Please set FREESURFER_LICENSE (content) or FS_LICENSE (path) in resource environment"
    exit 1
fi

# Pull image with retry (Docker Hub can drop connection on first attempt)
export SINGULARITY_CACHEDIR=${TMPDIR:-/tmp}/singularity_cache
mkdir -p $SINGULARITY_CACHEDIR

for i in 1 2 3; do
    singularity pull --force $SINGULARITY_CACHEDIR/freesurfer.sif docker://brainlife/freesurfer:7.1.1 && break
    echo "Pull attempt $i failed, retrying in 30s..."
    sleep 30
done

time singularity exec -e -B `pwd`/license.txt:/usr/local/freesurfer/license.txt $SINGULARITY_CACHEDIR/freesurfer.sif ./freesurfer.sh
